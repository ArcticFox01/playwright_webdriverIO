# Appium Server Configuration
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4730
APPIUM_PATH=/

# iOS Device Configuration
APPIUM_PLATFORM_NAME=iOS
APPIUM_DEVICE_NAME=Your Device Name
APPIUM_PLATFORM_VERSION=Your iOS Version
APPIUM_AUTOMATION_NAME=XCUITest
APPIUM_UDID=Your Device UDID
APPIUM_BUNDLE_ID=com.example.MiniMarket

# App Path
APPIUM_APP_PATH=/path/to/your/MiniMarket.app

# Test Configuration
DEFAULT_TIMEOUT=15000
APP_TIMEOUT=60000
